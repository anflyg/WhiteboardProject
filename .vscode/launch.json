{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Whiteboard (PySide6)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "QT_MAC_DISABLE_LIBRARY_VALIDATION": "1",
        "QT_QPA_PLATFORM": "cocoa",
        "QT_PLUGIN_PATH": "${workspaceFolder}/.venv/lib/python3.12/site-packages/PySide6/Qt/plugins",
        "QT_QPA_PLATFORM_PLUGIN_PATH": "${workspaceFolder}/.venv/lib/python3.12/site-packages/PySide6/Qt/plugins/platforms",
        "DYLD_FRAMEWORK_PATH": "${workspaceFolder}/.venv/lib/python3.12/site-packages/PySide6/Qt/lib",
        "DYLD_LIBRARY_PATH": "${workspaceFolder}/.venv/lib/python3.12/site-packages/PySide6/Qt/lib"
      }
    }
  ]
}
